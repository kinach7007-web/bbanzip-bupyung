{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A single income or expense transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "author": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM format for partitioning" }
      },
      "required": ["id", "date", "category", "name", "amount", "month"]
    },
    "CashBalanceData": {
      "title": "Cash Balance Data",
      "description": "Monthly cash balance state",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "title": { "type": "string" },
        "carryover": { "type": "number" },
        "isCarryoverFixed": { "type": "boolean" },
        "rows": { "type": "array" }
      },
      "required": ["month", "rows"]
    },
    "SalaryState": {
      "title": "Salary State",
      "description": "Monthly salary and insurance state",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "employees": { "type": "array" },
        "partTimeWorkers": { "type": "array" },
        "partTimeDays": { "type": "array" },
        "dispatchDays": { "type": "array" },
        "dispatchWorkers": { "type": "array" },
        "nationalHealth": { "type": "number" },
        "nationalPension": { "type": "number" },
        "employmentInsurance": { "type": "number" },
        "industrialAccidentInsurance": { "type": "number" }
      },
      "required": ["month"]
    },
    "MonthlyArchive": {
      "title": "Monthly Archive",
      "description": "Closed month summary and data snapshot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "string" },
        "summary": { "type": "object" },
        "timestamp": { "type": "string" },
        "data": { "type": "object" }
      },
      "required": ["id", "month", "summary", "data"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "vendorList": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All transactions"
    },
    "/cashBalanceData/{month}": {
      "schema": "CashBalanceData",
      "description": "Cash balance state per month"
    },
    "/salaryState/{month}": {
      "schema": "SalaryState",
      "description": "Salary state per month"
    },
    "/archives/{archiveId}": {
      "schema": "MonthlyArchive",
      "description": "Archived months"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global settings like vendor list"
    }
  }
}
